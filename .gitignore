# Template .gitignore for Task Management System
# Copy relevant parts to your .gitignore

# Personal task files (synced with Things 3)
things-sync/
!things-sync/.gitkeep
BACKLOG.md

# Personal knowledge files
Knowledge/*.md
!Knowledge/.gitkeep
!Knowledge/README.md

# Personal configuration
CLAUDE.md       # If customized from template
GOALS.md        # Personal goals

# Keep templates and examples
!CLAUDE_TEMPLATE.md
!config.example.yaml
!things-sync/example.md
!CRM/example.md

# Credentials & secrets
.env
.env.*
credentials.json
.claude/settings.local.json
**/token.json
**/tokens.json
core/integrations/google-drive/scripts/credentials.json
core/integrations/google-drive/scripts/token.json
core/integrations/mcp-servers/credentials/*.json

# Python
__pycache__/
*.py[cod]
*$py.class
.Python
venv/
.venv/
env/

# IDE & Editor configs
.vscode/
.idea/
.obsidian/
*.swp
*.swo
*~
.DS_Store

# Tool-specific
.specstory/
.factory/

# Logs
*.log
logs/

# Testing
test_*.py
*.test.py
.pytest_cache/
.coverage

# MCP/System
.mcp_cache/
*.pid
*.lock
