# Template .gitignore for Task Management System
# Copy relevant parts to your .gitignore

# Personal task files (synced with Things 3)
things-sync/
!things-sync/.gitkeep
BACKLOG.md

# Personal knowledge files and generated outputs
Knowledge/**
!Knowledge/
!Knowledge/.gitkeep
!Knowledge/README.md
brands/
meetings/
plans/
projects/

# Personal configuration
CLAUDE.md
GOALS.md

# Keep templates and examples
!CLAUDE_TEMPLATE.md
!config.example.yaml
!things-sync/example.md
!CRM/example.md

# Credentials & secrets
.env
.env.*
credentials.json
.claude/settings.local.json
**/token.json
**/tokens.json
core/integrations/google-drive/scripts/credentials.json
core/integrations/google-drive/scripts/token.json
core/integrations/mcp-servers/credentials/*.json

# Python
__pycache__/
*.py[cod]
*$py.class
.Python
venv/
.venv/
env/

# IDE & Editor configs
.vscode/
.idea/
.obsidian/
*.swp
*.swo
*~
.DS_Store

# Tool-specific
.specstory/
.factory/

# Logs
*.log
logs/

# Runtime state and local generated assets
core/state/
core/assets/

# Testing
test_*.py
*.test.py
.pytest_cache/
.coverage

# MCP/System
.mcp_cache/
*.pid
*.lock
