        <key>HOME</key>
        <string>/Users/matthewlieber</string>
        <key>USER</key>
        <string>matthewlieber</string>
        <key>SYSTEM_HEALTH_ROLE</key>
        <string>laptop</string>
    </dict>
</dict>
</plist>
