<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.matthewlieber.laptop.system-health</string>

    <key>ProgramArguments</key>
    <array>
        <string>/Users/matthewlieber/Obsidian/personal-os/core/automation/system-health.sh</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/matthewlieber/Obsidian/personal-os</string>

    <key>StartCalendarInterval</key>
