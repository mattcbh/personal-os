<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.brain.telegram-bridge</string>

    <key>ProgramArguments</key>
    <array>
        <string>/Users/homeserver/Obsidian/personal-os/core/automation/telegram-bridge.sh</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/homeserver/Obsidian/personal-os</string>

    <key>KeepAlive</key>
    <true/>

    <key>RunAtLoad</key>
    <true/>

    <key>ThrottleInterval</key>
    <integer>10</integer>

    <key>StandardOutPath</key>
    <string>/Users/homeserver/Obsidian/personal-os/logs/telegram-bridge-launchd.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/homeserver/Obsidian/personal-os/logs/telegram-bridge-launchd-error.log</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/opt/homebrew/sbin:/Users/homeserver/.local/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
        <key>HOME</key>
        <string>/Users/homeserver</string>
        <key>USER</key>
        <string>homeserver</string>
    </dict>
</dict>
</plist>
