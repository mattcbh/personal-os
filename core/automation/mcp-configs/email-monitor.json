{
  "mcpServers": {
    "google": {
      "command": "gws",
      "args": ["mcp", "-s", "gmail"],
      "env": {
        "GOOGLE_WORKSPACE_CLI_CREDENTIALS_FILE": "/Users/homeserver/.gmail-mcp/gws-authorized-user.json"
      }
    },
    "google-personal": {
      "command": "gws",
      "args": ["mcp", "-s", "gmail"],
      "env": {
        "GOOGLE_WORKSPACE_CLI_CREDENTIALS_FILE": "/Users/homeserver/.gmail-mcp-personal/gws-authorized-user.json"
      }
    },
    "contacts": {
      "command": "uv",
      "args": [
        "--directory",
        "/Users/homeserver/mcp-servers/contacts",
        "run",
        "--python",
        "3.12",
        "contacts-mcp-server"
      ]
    }
  }
}
